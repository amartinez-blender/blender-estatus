rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isDomainUser() {
      return isSignedIn()
        && request.auth.token.email.lower().matches('.*@(blendergroup|blendershop)[.]com$');
    }

    function isConfiguredSuperAdmin() {
      return request.auth.token.email.lower() in [
        'amartinez@blendergroup.com'
      ];
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isStaff() {
      return isDomainUser() && userExists() && userDoc().active == true;
    }

    function role() {
      return userDoc().role;
    }

    function hasRole(r) {
      return isStaff() && role() == r;
    }

    function isSuper() {
      return hasRole('superadmin');
    }

    function isValidRole(r) {
      return r in ['superadmin', 'sales_admin', 'sales_exec', 'production', 'warehouse', 'administration', 'auditor', 'pending'];
    }

    match /users/{userId} {
      allow read: if isDomainUser() && (userExists() || request.auth.uid == userId);

      allow create: if isDomainUser()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.active == true
        && isValidRole(request.resource.data.role)
        && (
          request.resource.data.role == 'pending'
          || (request.resource.data.role == 'superadmin' && isConfiguredSuperAdmin())
        );

      allow update: if isSuper()
        || (
          isDomainUser()
          && request.auth.uid == userId
          && request.resource.data.active == resource.data.active
          && (
            request.resource.data.role == resource.data.role
            || (request.resource.data.role == 'superadmin' && isConfiguredSuperAdmin())
          )
        );

      allow delete: if isSuper();
    }

    match /columns/{columnId} {
      allow read: if isStaff();
      allow create, update, delete: if isSuper();
    }

    match /orderNumbers/{orderNumber} {
      allow read: if isStaff();
      allow create: if (isSuper() || hasRole('sales_admin') || hasRole('sales_exec'))
        && orderNumber.matches('^[0-9]{1,5}$')
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if false;
      allow delete: if isSuper();
    }

    function isQuoteShipping(t) {
      return t.shippingType in ['Envío por cobrar', 'Envío pre-pagado'];
    }

    function canViewTicketData(t) {
      return isStaff() && role() != 'pending';
    }

    function canOperateTicketData(t) {
      return isSuper()
        || hasRole('sales_admin')
        || hasRole('administration')
        || (hasRole('sales_exec') && (t.ownerId == request.auth.uid || t.createdBy == request.auth.uid))
        || (hasRole('production') && t.treatment == 'Fabricación')
        // Almacén opera por TRATAMIENTO (sus pedidos) y por COLUMNA (las etapas que
        // atiende: cotización de envío y listos), sin importar el tratamiento.
        || (hasRole('warehouse') && (
              t.treatment == 'Almacén'
              || ticketColumnName(t) in ['Cotización de envío', 'Cotización de envío lista', 'Listos para recolección']
            ));
    }

    function parentTicket(ticketId) {
      return get(/databases/$(database)/documents/tickets/$(ticketId)).data;
    }

    // Nombre de la columna de un ticket (para permisos por columna).
    function ticketColumnName(t) {
      return get(/databases/$(database)/documents/columns/$(t.columnId)).data.name;
    }

    function isValidTicket(d) {
      return d.orderNumber is string && d.orderNumber.matches('^[0-9]{1,5}$')
        && (!('client' in d) || (d.client is string && d.client.size() <= 200))
        && d.treatment in ['Fabricación', 'Almacén']
        && d.shippingType in ['Recolección', 'Envío por cobrar', 'Envío pre-pagado']
        && d.deliveryMode in ['Domicilio', 'Ocurre', 'Recolección']
        && d.status in ['Activo', 'Cerrado', 'Cancelado']
        && d.columnId is string && d.columnId.size() > 0
        && d.ownerId is string && d.ownerId.size() > 0
        && (d.priority == null || d.priority in ['Baja', 'Media', 'Alta', 'Urgente'])
        && (!('tipoPago' in d) || d.tipoPago == null || d.tipoPago in ['Contado', 'Crédito', 'Pedido Autorizado'])
        && (!('paymentConfirmed' in d) || d.paymentConfirmed is bool)
        && (!('paymentMethod' in d) || d.paymentMethod == null || d.paymentMethod in ['Transferencia', 'Crédito', 'TDC', 'TDD', 'Nota de Crédito', 'Efectivo'])
        && (!('pedidoNumber' in d) || d.pedidoNumber == null || d.pedidoNumber is string)
        && (!('shippedAt' in d) || d.shippedAt == null || d.shippedAt is string)
        && d.addressNA is bool
        && d.shippingAddress is string && d.shippingAddress.size() <= 500
        && (d.addressNA == true || d.shippingAddress.size() > 0);
    }

    match /tickets/{ticketId} {

      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      function onlyMoveFields() {
        return changedKeys().hasOnly(['columnId', 'lastMovedAt', 'updatedAt']);
      }

      function onlyCounterFields() {
        return changedKeys().hasOnly(['commentsCount', 'attachmentsCount', 'updatedAt']);
      }

      function onlyProductionPromise() {
        return changedKeys().hasOnly(['promiseDateWarehouse', 'updatedAt']);
      }

      function onlyWarehousePromise() {
        return changedKeys().hasOnly(['promiseDateReady', 'updatedAt']);
      }

      function onlyShippingCost() {
        return changedKeys().hasOnly(['shippingCost', 'costDecision', 'columnId', 'lastMovedAt', 'updatedAt'])
          || changedKeys().hasOnly(['shippingCost', 'costDecision', 'updatedAt']);
      }

      function onlyCostDecisionMove() {
        return changedKeys().hasOnly(['costDecision', 'pedidoNumber', 'columnId', 'lastMovedAt', 'updatedAt']);
      }
      function onlyAcceptFlag() {
        return changedKeys().hasOnly(['costDecision', 'pedidoNumber', 'updatedAt']);
      }
      function onlyRejectMove() {
        return changedKeys().hasOnly(['shippingCost', 'costDecision', 'shippingPaidByClient', 'columnId', 'lastMovedAt', 'updatedAt']);
      }
      function onlyPaidMove() {
        return changedKeys().hasOnly(['shippingPaidByClient', 'columnId', 'lastMovedAt', 'updatedAt']);
      }
      function onlyConfirmPayment() {
        return changedKeys().hasOnly(['paymentConfirmed', 'paymentMethod', 'columnId', 'lastMovedAt', 'updatedAt']);
      }
      function onlyAddPedido() {
        return changedKeys().hasOnly(['pedidoNumber', 'columnId', 'lastMovedAt', 'updatedAt']);
      }
      // Almacén cierra en "Listos para recolección": cambia el estatus a Cerrado
      // y registra la Fecha y Hora de Envío (shippedAt).
      function onlyCloseByWarehouse() {
        return changedKeys().hasOnly(['status', 'shippedAt', 'updatedAt'])
          && request.resource.data.status == 'Cerrado';
      }

      allow read: if canViewTicketData(resource.data);

      allow create: if (isSuper() || hasRole('sales_admin') || hasRole('sales_exec'))
        && isValidTicket(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      // ── Ruta dedicada de Almacén en "Listos para recolección" ──
      // Cierre + incremento del contador de adjuntos. Es AUTÓNOMA: no re-valida todo
      // el ticket (isValidTicket) ni depende de campos heredados, así funciona en
      // CUALQUIER ticket —viejo o nuevo, de cualquier tratamiento—.
      // `onlyCloseByWarehouse`/`onlyCounterFields` ya restringen qué campos cambian.
      // La evidencia se exige y se sube en el cliente; NO se gatea el cierre con el
      // contador (evita fallos si el incremento del contador no alcanzó a persistir).
      allow update: if (
          hasRole('warehouse')
          && ticketColumnName(resource.data) == 'Listos para recolección'
          && (
            onlyCounterFields()
            || onlyCloseByWarehouse()
          )
        )
        || (
          isValidTicket(request.resource.data)
          && request.resource.data.orderNumber == resource.data.orderNumber
          && request.resource.data.createdBy == resource.data.createdBy
          && (
            isSuper()
            || hasRole('sales_admin')
            || (
              hasRole('sales_exec')
              && (resource.data.ownerId == request.auth.uid || resource.data.createdBy == request.auth.uid)
              && request.resource.data.columnId == resource.data.columnId
            )
            || (
              hasRole('sales_exec') && resource.data.createdBy == request.auth.uid
              && (onlyCostDecisionMove() || onlyAcceptFlag() || onlyRejectMove())
            )
            || (
              hasRole('sales_exec') && resource.data.ownerId == request.auth.uid
              && (onlyPaidMove() || onlyAddPedido())
            )
            || (hasRole('production') && resource.data.treatment == 'Fabricación' && onlyMoveFields())
            // Almacén mueve tickets de las columnas que atiende (por columna, no por tratamiento).
            || (hasRole('warehouse') && ticketColumnName(resource.data) in ['Almacén', 'Cotización de envío', 'Cotización de envío lista'] && onlyMoveFields())
            // Fecha y Hora promesa: según la COLUMNA donde está el ticket (no el tratamiento).
            || (hasRole('production') && ticketColumnName(resource.data) == 'Fabricación' && onlyProductionPromise())
            || (hasRole('warehouse') && ticketColumnName(resource.data) == 'Almacén' && onlyWarehousePromise())
            || (hasRole('warehouse') && isQuoteShipping(resource.data) && onlyShippingCost())
            || (hasRole('administration') && onlyConfirmPayment())
            || (canOperateTicketData(resource.data) && onlyCounterFields())
          )
        );

      allow delete: if isSuper();

      match /comments/{commentId} {
        allow read: if canViewTicketData(parentTicket(ticketId));

        // Cualquier usuario operativo (no pendiente) puede comentar en cualquier tarjeta.
        allow create: if isStaff() && role() != 'pending'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.deleted == false;

        // Editar / soft-delete: el autor o el SuperAdmin.
        allow update: if isSuper()
          || (
            isStaff()
            && resource.data.createdBy == request.auth.uid
            && request.resource.data.createdBy == resource.data.createdBy
          );

        allow delete: if isSuper();
      }

      match /attachments/{attachmentId} {
        allow read: if canViewTicketData(parentTicket(ticketId));

        allow create: if (
            canOperateTicketData(parentTicket(ticketId))
            // Almacén puede adjuntar evidencia en "Listos para recolección".
            || (hasRole('warehouse') && ticketColumnName(parentTicket(ticketId)) == 'Listos para recolección')
          )
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.fileType in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf']
          && request.resource.data.fileSize is number
          && request.resource.data.fileSize <= 10 * 1024 * 1024;

        allow update: if false;

        allow delete: if isSuper()
          || (
            resource.data.uploadedBy == request.auth.uid
            && canOperateTicketData(parentTicket(ticketId))
          );
      }

      match /activity/{activityId} {
        allow read: if canViewTicketData(parentTicket(ticketId));

        allow create: if (
            canOperateTicketData(parentTicket(ticketId))
            // Almacén registra actividad al cerrar en "Listos para recolección"
            // (aunque el tratamiento del pedido sea Fabricación).
            || (hasRole('warehouse') && ticketColumnName(parentTicket(ticketId)) == 'Listos para recolección')
          )
          && request.resource.data.actorId == request.auth.uid;

        allow update, delete: if false;
      }
    }

    match /{path=**}/activity/{activityId} {
      allow read: if isSuper() || hasRole('sales_admin') || hasRole('auditor');
    }

    match /notifications/{notificationId} {
      allow read: if isSuper() || (isStaff() && resource.data.recipientId == request.auth.uid);

      allow create: if isStaff()
        && role() != 'auditor'
        && request.resource.data.read == false
        && request.resource.data.recipientId is string;

      allow update: if isStaff()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isSuper() || (isStaff() && resource.data.recipientId == request.auth.uid);
    }

    match /slaBreaches/{breachId} {
      allow read: if isStaff() && role() != 'pending';
      allow create: if isStaff()
        && role() != 'auditor'
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.lateMs is number;
      allow update: if false;
      allow delete: if isSuper();
    }

    // Tiempos por etapa para los promedios del Dashboard.
    match /stepTimes/{stepId} {
      allow read: if isStaff() && role() != 'pending';
      allow create: if isStaff()
        && role() != 'auditor'
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.ms is number;
      allow update: if false;
      allow delete: if isSuper();
    }

    match /settings/{docId} {
      allow read: if isStaff();
      allow write: if isSuper();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}